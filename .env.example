# AI Bridge (codex oder claude)
BRIDGE=codex

# Server
PORT=3000

# Codex Bridge (OpenAI)
# OPENAI_API_KEY=sk-...
# CODEX_PATH=/path/to/codex
# CODEX_MODEL=gpt-5.4

# Claude Bridge (Anthropic)
# CLAUDE_PATH=/path/to/claude
# MCP_SSE_URL=http://localhost:3000/sse

# WebSocket Security
# ALLOWED_ORIGINS=http://192.168.x.x:3000
# ALLOW_NO_ORIGIN=true
# TRUST_PROXY=loopback

# Limits
# MAX_SESSIONS=50
# RATE_LIMIT_PER_MIN=10
# API_RATE_LIMIT_PER_MIN=60
# MAX_MESSAGE_LENGTH=2000

# Vault (nur in Docker relevant)
# VAULT_PATH=/app/vault
